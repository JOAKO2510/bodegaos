# BodegaOS — Variables de entorno
# Copia este archivo como .env y ajusta los valores

# Base de datos
DATABASE_URL=sqlite:///./bodegaos.db

# Aplicación
APP_NAME=BodegaOS
APP_VERSION=1.0.0
DEBUG=True

# CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Stock
STOCK_MINIMO_DEFAULT=5
